# HealthLink Environment Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# REQUIRED API KEYS
# ===========================================

# Gemini API Key (REQUIRED)
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone API Key (REQUIRED for RAG)
# Get your API key from: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# Set true to run agents without Gemini/Pinecone calls
OFFLINE_MODE=false

# Embedding model for RAG (Sentence-Transformers)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
